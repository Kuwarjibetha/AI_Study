      "source": [
        "n = int(input(\"enter prime number:\"))\n",
        "\n",
        "C=0\n",
        "p=0\n",
        "\n",
        "while C< n:\n",
        "\n",
        "  C=C+1\n",
        "  if n%C==0:\n",
        "      p=p+1\n",
        "if p==2:\n",
        "  print('prime')\n",
        "else:\n",
        "  print( 'not prime')\n",
        "\n"
      ]
